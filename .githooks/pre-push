#!/usr/bin/env bash
#
# Opt-in pre-push gate. Runs the same checks CI enforces so a red tree never
# reaches the remote. This hook is not active until a clone opts in with:
#
#     git config core.hooksPath .githooks
#
# It runs `bun run check` (oxlint + tsc -b + bun test + vite build); a non-zero
# exit aborts the push. Bypass a single push in an emergency with `--no-verify`.
set -euo pipefail

echo "revu pre-push: running 'bun run check'…"
bun run check
